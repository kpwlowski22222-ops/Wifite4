# =============================================================================
# KFIOSA / Wifite4 — environment template
# =============================================================================
# Copy to `.env` and fill in the keys you use:
#   cp .env.example .env
#
# Every key is optional unless a feature docs say otherwise. Missing keys
# degrade honestly (TUI shows MISSING / empty enrichment) — never fake data.
#
# NEVER commit your real `.env` (gitignored).
# In Python tools:
#   from core.env_loader import env, require_env, load_project_env, credentials_status
#   load_project_env()
#   nvd = env("NVD_API_KEY")
# =============================================================================

# ---- Ollama (primary LLM) ----
# Cloud token for minimax-m3:cloud / ollama.com
OLLAMA_CLOUD_TOKEN=""
# Alias used by some debug paths
OLLAMA_AUTH_TOKEN=""
# Override primary model tag (e.g. minimax-m3:cloud, qwen2.5-coder:14b)
OLLAMA_DEFAULT_MODEL=""
# Local daemon (default http://127.0.0.1:11434)
OLLAMA_HOST="http://127.0.0.1:11434"
# Set 0 to skip bootstrap model pulls
KFIOSA_OLLAMA_PULL="1"

# ---- Cloud LLM fallbacks ----
GROQ_API_KEY=""
GROQ_MODEL=""
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL=""
GEMINI_API_KEY=""
GEMINI_MODEL=""
# NVIDIA NIM / NGC
NVIDIA_API_KEY=""
NGC_API_KEY=""
NVIDIA_MODEL=""
NVIDIA_BASE_URL=""
NVIDIA_NIM_ENDPOINT=""
# xAI Grok (also accepted as XAI_API_KEY)
GROK_API_KEY=""
XAI_API_KEY=""
GROK_MODEL=""

# ---- OSINT / CVE / intel ----
SHODAN_API_KEY=""
# Strongly recommended for NVD rate limits
NVD_API_KEY=""
# Hugging Face (gated models / hub)
HF_TOKEN=""
# Have I Been Pwned (either name)
HIBP_API_KEY=""
KFIOSA_HIBP_KEY=""
# Polish registries (OSINT ext)
GUS_BIR1_KEY=""
ALLEGRO_CLIENT_ID=""
ALLEGRO_CLIENT_SECRET=""
KFIOSA_JURISDICTION=""

# ---- Kismet ----
# Optional API token from Kismet web UI /auth/apikey/list.json
KISMET_API_KEY=""
# HTTP basic for local Kismet (often admin/admin after first setup)
KISMET_CLIENT_USERNAME="admin"
KISMET_CLIENT_PASSWORD="admin"

# ---- Metasploit RPC (optional) ----
MSF_HOST="127.0.0.1"
MSF_PORT="55553"
MSF_USER="msf"
MSF_PASSWORD=""

# ---- Google Cloud (optional) ----
GOOGLE_PROJECT_ID=""

# ---- Flask / RAT dashboard ----
# Bind address (127.0.0.1 local; 0.0.0.0 requires RAT_DASHBOARD_TOKEN)
RAT_DASHBOARD_HOST="127.0.0.1"
RAT_DASHBOARD_PORT=""
# Required only when RAT_DASHBOARD_HOST is 0.0.0.0
RAT_DASHBOARD_TOKEN=""
# Optional path allowlist for file browser (colon-separated)
RAT_ALLOWED_PATHS=""
KFIOSA_RAT_JOBS=""

# ---- External scan terminals / geometry ----
# Font scale for triple WiFi/BLE scan windows (1.0 = main TUI density)
KFIOSA_SCAN_FONT_SCALE="1.0"
KFIOSA_SCREEN_W=""
KFIOSA_SCREEN_H=""
# Force terminal binary (xterm, kitty, foot, alacritty, …)
KFIOSA_TERMINAL=""
KFIOSA_PYTHON=""
KFIOSA_SCAN_BUS=""
KFIOSA_BLE_SCAN_BUS=""

# ---- Orchestrator / engagement knobs ----
KFIOSA_RECON_BUDGET_S=""
KFIOSA_SKIP_NVD=""
KFIOSA_FORCE_NVD=""
KFIOSA_SKIP_BLE_RECON=""
KFIOSA_FORCE_BLE_RECON=""
KFIOSA_LHOST=""
KFIOSA_LPORT=""
LHOST=""
LPORT=""
KFIOSA_MCP_AUTOSTART="1"
KFIOSA_MCP_HOST="127.0.0.1"
KFIOSA_MCP_PORT=""
KFIOSA_MCP_ALLOW_EXEC=""
KFIOSA_AUTO_INSTALL_TOOLS=""
KFIOSA_ZERO_DAY_TAIL_AUTO=""
KFIOSA_DEEP_THINKING="1"
KFIOSA_DEEP_THINKING_FORCE=""
USE_OFFLINE_FIRST=""

# ---- SQL store (optional; default sqlite) ----
# e.g. sqlite:////path/to/kfiosa.db or postgresql+psycopg2://user:pass@host/db
KFIOSA_SQL_URL=""

# ---- Holo desktop agent ----
HOLO_BASE_URL=""
HOLO_MODEL=""
KFIOSA_HOLO_BASE_URL=""
KFIOSA_HOLO_MODEL=""
KFIOSA_HOLO_FAKE=""

# ---- Zero-day sandbox (optional Docker) ----
KFIOSA_ZD_DOCKER_CPUS=""
KFIOSA_ZD_DOCKER_MEM=""
KFIOSA_DATA_DIR=""
KFIOSA_SECRETSDUMP_PW_FILE=""

# ---- holaOS-inspired continuity (native KFIOSA, no Electron required) ----
# Working memory notes under data/memory/
KFIOSA_MEMORY="1"
KFIOSA_MEMORY_ROOT=""
# Session compaction for long AI re-plans
KFIOSA_SESSION_COMPACT="1"
KFIOSA_COMPACT_AFTER_STEPS="8"
KFIOSA_COMPACT_KEEP_RECENT="4"
# Engagement workspaces under data/workspaces/
KFIOSA_WORKSPACE_ROOT=""
# Optional path if you installed holaOS separately (https://github.com/holaboss-ai/holaOS)
HOLAOS_HOME=""

# ---- Full-auto lab + OS agent ----
# Explicit lab mode: auto-pick scan targets, until-access loops
KFIOSA_FULL_AUTO="0"
# Only if you also want destructive PE steps auto-ACCEPTed (dangerous)
KFIOSA_AUTO_ACCEPT_DESTRUCTIVE="0"
# Anomaly hang threshold (seconds)
KFIOSA_ANOMALY_SLOW_S="45"
KFIOSA_UI_LABELS_ROOT=""
# Catalog SQL store (all catalog/*.json projected into SQLite)
# Default: ~/.kfiosa/catalog.db
KFIOSA_CATALOG_DB=""
# Background disk count + incremental ingest (1=on at dashboard start)
KFIOSA_CATALOG_BG="0"
# Optional accel for bg batch: cpu | npu | gpu (auto-detect if empty)
KFIOSA_CATALOG_ACCEL=""
# Learn mode — QLoRA heavy train (needs torch + VRAM); else datasets only
KFIOSA_LEARN_HEAVY="0"
KFIOSA_LEARN_FT_TIMEOUT="7200"
# MemOS long-term memory (local data/memos/; optional remote)
KFIOSA_MEMOS_ROOT=""
KFIOSA_MEMOS_DB=""
MEMOS_URL=""
MEMOS_API_KEY=""
# MCP catalog bridge — expand every catalog entry as tools/list items
KFIOSA_MCP_EXPAND_CATALOG="1"
# After full SQL ingest, raise toward full inventory size (~5k)
KFIOSA_MCP_CATALOG_EXPAND_LIMIT="5000"
# KFIOSA_MCP_ALLOW_EXEC=1  # allow run_tool / catalog_run (default off)

# ---- Deployment / misc ----
APP_URL=""
KFIOSA_SMOKE=""
KFIOSA_TUI_SCREEN_DUMP=""
KFIOSA_DEBUG_OLLAMA_MODEL=""
