# KFIOSA environment template.
# Copy to `.env` and fill in only the keys you actually use. Every key is
# optional — KFIOSA degrades gracefully (Ollama primary, then Groq, then a
# real heuristic planner) and reports honest "MISSING" status in the TUI.
# Never commit your real `.env`. Values shown here are intentionally blank.

# ---- AI providers ----

# GROQ_API_KEY: optional. Enables the Groq fallback planner behind Ollama.
# If unset, KFIOSA uses the local Ollama backend + heuristic planner only.
GROQ_API_KEY=""

# GROQ_MODEL: Groq model tag (used only when GROQ_API_KEY is set).
# Example: openai/gpt-oss-120b
GROQ_MODEL=""

# GEMINI_API_KEY: optional. Enables Gemini-backed plan/report routes.
# Leave empty to use Ollama-only flows.
GEMINI_API_KEY=""

# ---- OSINT / CVE integrations ----

# SHODAN_API_KEY: optional. Enables Shodan host/port enrichment (OSINT screen).
SHODAN_API_KEY=""

# NVD_API_KEY: optional but recommended. Raises the NVD CVE API rate limit
# (without it you are capped at ~5 requests / 30s). Used by the CVE Lookup
# action and the orchestrator's NVD step.
NVD_API_KEY=""

# ---- Hugging Face (optional) ----
# HF_TOKEN: optional. Needed only to pull gated HuggingFace repos (the
# 0-day triage classifier cpranavsharma/Zero-Day-Agent is ungated, so this
# is usually unneeded). Read by ZeroDayClassifier and ExploitGenModelManager.
HF_TOKEN=""

# ---- Google Cloud (optional, unused by the curses TUI core) ----

# GOOGLE_PROJECT_ID: optional. Only relevant if you wire a Google Cloud
# integration yourself; the TUI does not require it.
GOOGLE_PROJECT_ID=""

# ---- Deployment ----

# APP_URL: optional public URL for deployments that need self-referential
# links. Not required for local TUI operation.
APP_URL=""